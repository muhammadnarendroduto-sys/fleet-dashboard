<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Dashboard KPI Fleet — KBM Investasi</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
<style>
  :root {
    --bg:#F4F6FA; --white:#FFFFFF; --text:#1A1D23; --text2:#6B7280; --text3:#9CA3AF;
    --border:#E5E7EB; --sh:0 1px 3px rgba(0,0,0,.07),0 1px 2px rgba(0,0,0,.05);
    --sh2:0 4px 12px rgba(0,0,0,.08); --sw:220px;
  }
  *{margin:0;padding:0;box-sizing:border-box;}
  body{background:var(--bg);color:var(--text);font-family:'Inter',sans-serif;font-size:14px;display:flex;min-height:100vh;}

  /* SIDEBAR */
  .sidebar{width:var(--sw);background:var(--white);border-right:1px solid var(--border);display:flex;flex-direction:column;position:fixed;top:0;left:0;bottom:0;z-index:50;}
  .sb-logo{padding:1.25rem 1.5rem;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:.6rem;}
  .sb-icon{width:32px;height:32px;border-radius:8px;background:linear-gradient(135deg,#6366F1,#8B5CF6);display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0;}
  .sb-name{font-size:.82rem;font-weight:700;color:var(--text);line-height:1.2;}
  .sb-name span{display:block;font-size:.68rem;font-weight:400;color:var(--text2);}
  .sb-nav{padding:1rem .75rem;flex:1;}
  .nav-lbl{font-size:.63rem;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:.8px;padding:0 .75rem;margin-bottom:.4rem;margin-top:1rem;}
  .nav-item{display:flex;align-items:center;gap:.6rem;padding:.55rem .75rem;border-radius:8px;font-size:.82rem;font-weight:500;color:var(--text2);cursor:pointer;transition:all .15s;margin-bottom:2px;text-decoration:none;}
  .nav-item:hover{background:var(--bg);color:var(--text);}
  .nav-item.on{background:#EEF2FF;color:#4338CA;}
  .sb-foot{padding:1rem 1.5rem;border-top:1px solid var(--border);font-size:.7rem;color:var(--text3);}
  .live-dot{display:inline-flex;align-items:center;gap:.35rem;color:#065F46;font-size:.7rem;}
  .live-dot::before{content:'';width:6px;height:6px;border-radius:50%;background:#34D399;animation:lp 2s infinite;flex-shrink:0;}
  @keyframes lp{0%,100%{opacity:1}50%{opacity:.5}}

  /* MAIN */
  .main{margin-left:var(--sw);flex:1;display:flex;flex-direction:column;}
  .topbar{background:var(--white);border-bottom:1px solid var(--border);padding:0 2rem;height:56px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:40;}
  .tb-left{display:flex;align-items:center;gap:.5rem;}
  .tb-title{font-size:.9rem;font-weight:600;color:var(--text);}
  .tb-sub{font-size:.8rem;color:var(--text3);}
  .tb-right{display:flex;align-items:center;gap:.75rem;}
  .sync-info{font-size:.71rem;color:var(--text3);text-align:right;line-height:1.5;}
  .sync-info strong{display:block;color:var(--text2);font-size:.72rem;font-weight:500;}
  .cd-badge{padding:.3rem .7rem;border-radius:999px;background:#ECFDF5;color:#065F46;font-size:.69rem;font-weight:600;border:1px solid #A7F3D0;display:flex;align-items:center;gap:.35rem;}
  .cd-badge::before{content:'';width:6px;height:6px;border-radius:50%;background:#34D399;animation:lp 2s infinite;}
  .btn-ref{display:inline-flex;align-items:center;gap:.4rem;padding:.42rem 1rem;border-radius:8px;background:#4F46E5;color:white;font-size:.77rem;font-weight:500;cursor:pointer;border:none;transition:background .2s;font-family:'Inter',sans-serif;}
  .btn-ref:hover{background:#4338CA;}
  .btn-ref.loading svg{animation:spin .7s linear infinite;}
  @keyframes spin{to{transform:rotate(360deg)}}

  /* CONTENT */
  .content{padding:1.75rem 2rem 3rem;}
  .sec-title{font-size:.78rem;font-weight:600;color:var(--text);margin-bottom:.85rem;}

  /* STATUS CARDS */
  .sg{display:grid;grid-template-columns:repeat(auto-fill,minmax(145px,1fr));gap:.85rem;margin-bottom:1.75rem;}
  .sc{background:var(--white);border-radius:14px;padding:1.1rem 1.2rem;box-shadow:var(--sh);border:1px solid var(--border);transition:transform .2s,box-shadow .2s;cursor:default;}
  .sc:hover{transform:translateY(-2px);box-shadow:var(--sh2);}
  .sc-icon{width:30px;height:30px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:.95rem;margin-bottom:.7rem;}
  .sc-val{font-size:2rem;font-weight:700;line-height:1;margin-bottom:.2rem;}
  .sc-lbl{font-size:.72rem;font-weight:500;color:var(--text2);}
  .sc-pct{font-size:.67rem;color:var(--text3);margin-top:.15rem;}

  .cteal{background:#E6FAF8;}.cteal .sc-val{color:#0F766E;}.cteal .sc-icon{background:#CCFBF1;}
  .cpink{background:#FEF2F2;}.cpink .sc-val{color:#991B1B;}.cpink .sc-icon{background:#FEE2E2;}
  .camber{background:#FEF3C7;}.camber .sc-val{color:#92400E;}.camber .sc-icon{background:#FDE68A;}
  .cpurple{background:#F5F3FF;}.cpurple .sc-val{color:#5B21B6;}.cpurple .sc-icon{background:#EDE9FE;}
  .cblue{background:#EFF6FF;}.cblue .sc-val{color:#1D4ED8;}.cblue .sc-icon{background:#DBEAFE;}
  .cindigo{background:#EEF2FF;}.cindigo .sc-val{color:#3730A3;}.cindigo .sc-icon{background:#E0E7FF;}

  /* KPI */
  .kgrid{display:grid;grid-template-columns:1fr 1fr;gap:.85rem;margin-bottom:1.75rem;}
  @media(max-width:720px){.kgrid{grid-template-columns:1fr}}
  .kc{background:var(--white);border-radius:14px;padding:1.4rem 1.5rem;box-shadow:var(--sh);border:1px solid var(--border);}
  .kc.kpass{border-left:4px solid #34D399;}.kc.kfail{border-left:4px solid #F87171;}
  .kh{display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem;gap:.5rem;flex-wrap:wrap;}
  .klbl{font-size:.73rem;font-weight:600;color:var(--text2);text-transform:uppercase;letter-spacing:.5px;}
  .badge{display:inline-flex;align-items:center;gap:.3rem;padding:.22rem .65rem;border-radius:999px;font-size:.67rem;font-weight:600;}
  .badge.pass{background:#ECFDF5;color:#065F46;border:1px solid #A7F3D0;}
  .badge.fail{background:#FEF2F2;color:#991B1B;border:1px solid #FECACA;}
  .knum{display:flex;align-items:baseline;gap:.5rem;margin-bottom:.75rem;}
  .kbig{font-size:2.2rem;font-weight:700;line-height:1;}
  .ktgt{font-size:.77rem;color:var(--text3);}
  .pt{height:8px;background:#F3F4F6;border-radius:999px;position:relative;margin-bottom:.4rem;}
  .pf{height:100%;border-radius:999px;transition:width 1s cubic-bezier(.4,0,.2,1);}
  .pm{position:absolute;top:-4px;bottom:-4px;width:2px;background:#D1D5DB;border-radius:2px;}
  .pl{display:flex;justify-content:space-between;font-size:.64rem;color:var(--text3);}
  .knote{margin-top:.85rem;padding:.5rem .85rem;border-radius:8px;font-size:.74rem;font-weight:500;}
  .knote.pass{background:#ECFDF5;color:#065F46;}.knote.fail{background:#FEF2F2;color:#991B1B;}

  /* MID */
  .mgrid{display:grid;grid-template-columns:290px 1fr;gap:.85rem;margin-bottom:1.75rem;}
  @media(max-width:900px){.mgrid{grid-template-columns:1fr}}
  .card{background:var(--white);border-radius:14px;padding:1.25rem 1.4rem;box-shadow:var(--sh);border:1px solid var(--border);}
  .card h3{font-size:.72rem;font-weight:600;color:var(--text2);text-transform:uppercase;letter-spacing:.5px;margin-bottom:.9rem;}
  .rlist{display:flex;flex-direction:column;gap:.55rem;}
  .ri{display:flex;align-items:center;gap:.65rem;}
  .rn{font-size:.72rem;color:var(--text2);width:130px;flex-shrink:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
  .rbw{flex:1;height:6px;background:#F3F4F6;border-radius:999px;overflow:hidden;}
  .rb{height:100%;border-radius:999px;background:#818CF8;transition:width .7s;}
  .rc{font-size:.71rem;font-weight:600;color:var(--text);width:24px;text-align:right;flex-shrink:0;}
  .rbd{font-size:.64rem;color:#991B1B;width:50px;flex-shrink:0;}

  /* ERR */
  .err-bar{background:#FEF2F2;border:1px solid #FECACA;border-radius:10px;padding:.75rem 1.1rem;margin-bottom:1.25rem;font-size:.77rem;color:#991B1B;display:none;align-items:center;gap:.6rem;}

  /* TABLE */
  .tcard{background:var(--white);border-radius:14px;padding:1.25rem 1.4rem;box-shadow:var(--sh);border:1px solid var(--border);overflow-x:auto;}
  .fstrip{display:flex;gap:.4rem;flex-wrap:wrap;margin-bottom:.9rem;align-items:center;}
  .fb{padding:.26rem .75rem;border-radius:999px;border:1px solid var(--border);background:var(--white);color:var(--text2);font-size:.71rem;font-weight:500;cursor:pointer;transition:all .15s;font-family:'Inter',sans-serif;}
  .fb:hover{border-color:#818CF8;color:#4338CA;}
  .fb.on{background:#EEF2FF;border-color:#818CF8;color:#4338CA;}
  .sbox{margin-left:auto;padding:.28rem .75rem;border-radius:8px;border:1px solid var(--border);background:var(--bg);color:var(--text);font-size:.72rem;font-family:'Inter',sans-serif;outline:none;width:175px;transition:border-color .2s;}
  .sbox::placeholder{color:var(--text3);}
  .sbox:focus{border-color:#818CF8;}
  table{width:100%;border-collapse:collapse;font-size:.79rem;min-width:560px;}
  thead tr{border-bottom:2px solid var(--bg);}
  thead th{padding:.48rem .7rem;text-align:left;color:var(--text3);font-weight:600;font-size:.65rem;letter-spacing:.5px;text-transform:uppercase;white-space:nowrap;}
  tbody tr{border-bottom:1px solid var(--bg);transition:background .1s;}
  tbody tr:hover{background:#F9FAFB;}
  tbody td{padding:.55rem .7rem;color:var(--text);white-space:nowrap;}
  tbody td.d{color:var(--text2);}
  .pill{display:inline-block;padding:.18rem .6rem;border-radius:999px;font-size:.66rem;font-weight:600;}
  .pREADY{background:#ECFDF5;color:#065F46;}
  .pBREAKDOWN{background:#FEF2F2;color:#991B1B;}
  .pMANGKRAK{background:#FEF3C7;color:#92400E;}
  .pLAKA{background:#F5F3FF;color:#5B21B6;}
  .pPROGRES{background:#EFF6FF;color:#1D4ED8;}
  .pgrow{display:flex;align-items:center;justify-content:space-between;margin-top:.8rem;flex-wrap:wrap;gap:.5rem;}
  .pginfo{font-size:.69rem;color:var(--text3);}
  .pgbtns{display:flex;gap:.28rem;}
  .pgb{padding:.25rem .6rem;border-radius:6px;border:1px solid var(--border);background:var(--white);color:var(--text2);font-size:.71rem;cursor:pointer;transition:all .15s;font-family:'Inter',sans-serif;}
  .pgb:hover:not(:disabled){border-color:#818CF8;color:#4338CA;}
  .pgb:disabled{opacity:.3;cursor:default;}
  .pgb.on{background:#EEF2FF;border-color:#818CF8;color:#4338CA;}

  .state-box{text-align:center;padding:5rem 2rem;color:var(--text3);}
  .state-box h2{font-size:1rem;color:var(--text);margin:.85rem 0 .4rem;}
  .state-box p{font-size:.79rem;line-height:1.7;}
  .spinner{width:32px;height:32px;border-radius:50%;border:2.5px solid var(--border);border-top-color:#4F46E5;animation:spin .8s linear infinite;margin:0 auto;}

  @keyframes fadeUp{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
  .fu{animation:fadeUp .35s ease both;}
  .fu1{animation-delay:.04s}.fu2{animation-delay:.09s}.fu3{animation-delay:.14s}.fu4{animation-delay:.19s}

  @media(max-width:768px){
    .sidebar{display:none;}.main{margin-left:0;}
    .content{padding:1rem;}.topbar{padding:0 1rem;}
  }
</style>

  <!-- PWA -->
  <meta name="mobile-web-app-capable" content="yes"/>
  <meta name="apple-mobile-web-app-capable" content="yes"/>
  <meta name="apple-mobile-web-app-status-bar-style" content="default"/>
  <meta name="apple-mobile-web-app-title" content="KPI Fleet"/>
  <meta name="theme-color" content="#4F46E5"/>
  <link rel="manifest" href="manifest.json"/>
  <link rel="apple-touch-icon" href="icon-192.png"/>
</head>
<body>
<div id="installBanner" style="display:none;position:fixed;bottom:1rem;left:50%;transform:translateX(-50%);z-index:9999;background:#4F46E5;color:white;padding:.75rem 1.25rem;border-radius:12px;display:none;align-items:center;gap:.75rem;box-shadow:0 4px 20px rgba(79,70,229,.4);font-family:Inter,sans-serif;font-size:.82rem;white-space:nowrap;">
  <span>📱 Install sebagai aplikasi</span>
  <button id="btnInstall" style="background:white;color:#4F46E5;border:none;padding:.35rem .85rem;border-radius:8px;font-weight:600;font-size:.78rem;cursor:pointer;font-family:Inter,sans-serif;">Install</button>
  <button onclick="document.getElementById('installBanner').style.display='none'" style="background:rgba(255,255,255,.2);color:white;border:none;padding:.35rem .6rem;border-radius:8px;cursor:pointer;font-size:.8rem;">✕</button>
</div>

<aside class="sidebar">
  <div class="sb-logo">
    <div class="sb-icon">🚛</div>
    <div class="sb-name">Fleet Dashboard<span>PT Pos Logistik Indonesia</span></div>
  </div>
  <nav class="sb-nav">
    <div class="nav-lbl">Menu</div>
    <a class="nav-item on">
      <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
      Dashboard KPI Fleet
    </a>
  </nav>
  <div class="sb-foot">
    <div class="live-dot" id="liveStatus">LIVE · Auto-refresh 5 menit</div>
    <div style="margin-top:.35rem;font-size:.66rem;" id="sbTime">—</div>
  </div>
</aside>

<div class="main">
  <div class="topbar">
    <div class="tb-left">
      <span class="tb-title">Dashboard Overview</span>
      <span style="color:var(--border)">·</span>
      <span class="tb-sub">KBM Investasi</span>
    </div>
    <div class="tb-right">
      <div class="cd-badge" id="cdBadge">5:00</div>
      <div class="sync-info">
        <strong id="syncTime">Memuat data...</strong>
        <span id="syncSub">Google Sheets</span>
      </div>
      <button class="btn-ref" id="btnRef" onclick="loadData(true)">
        <svg id="refIcon" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99"/>
        </svg>
        Refresh
      </button>
    </div>
  </div>

  <div class="content">
    <div class="err-bar" id="errBar">⚠ <span id="errMsg"></span></div>
    <div id="dash">
      <div class="state-box">
        <div class="spinner"></div>
        <h2>Mengambil data dari Google Sheets...</h2>
        <p>Mohon tunggu sebentar.</p>
      </div>
    </div>
  </div>
</div>

<script>
const API_URL="https://script.google.com/macros/s/AKfycbzIfHvkTwK9ns1R2kGvOCPTZde2xcq69DrGyaZv-rI-0ih48fwx8VH_tsrO4Ga7KBcmVQ/exec";
const REFRESH_MS=5*60*1000, KPI_R=90, KPI_B=10, PG=15;
let allUnits=[],filteredUnits=[],curFilter="ALL",curPage=1,searchQ="";
let donutChart=null,cdLeft=REFRESH_MS,cdTimer=null;

function startCd(){
  clearInterval(cdTimer); cdLeft=REFRESH_MS;
  cdTimer=setInterval(()=>{
    cdLeft-=1000; if(cdLeft<0)cdLeft=REFRESH_MS;
    const m=Math.floor(cdLeft/60000),s=String(Math.floor((cdLeft%60000)/1000)).padStart(2,"0");
    const el=document.getElementById("cdBadge"); if(el)el.textContent=`${m}:${s}`;
  },1000);
}

async function loadData(){
  const btn=document.getElementById("btnRef");
  if(btn)btn.classList.add("loading");
  try{
    const res=await fetch(API_URL);
    if(!res.ok)throw new Error(`HTTP ${res.status}`);
    const json=await res.json();
    const rows=json.data||json;

    let hIdx=-1;
    for(let i=0;i<Math.min(rows.length,10);i++){
      const c=rows[i].map(x=>String(x).toUpperCase().trim());
      if(c.includes("STATUS")&&c.includes("NOPOL")){hIdx=i;break;}
    }
    if(hIdx<0)throw new Error("Kolom STATUS/NOPOL tidak ditemukan.");

    const hdrs=rows[hIdx].map(x=>String(x).toUpperCase().trim());
    const ci=n=>hdrs.indexOf(n), cip=p=>hdrs.findIndex(h=>h.includes(p));
    const cv=(r,i)=>i>=0&&i<r.length?String(r[i]||"").trim():"";
    const iSt=ci("STATUS"),iNo=ci("NOPOL"),iReg=cip("REGIONAL"),iTh=cip("TAHUN"),iJn=cip("JENIS"),iMr=ci("MEREK"),iBs=ci("BISNIS");

    allUnits=[];
    for(let i=hIdx+1;i<rows.length;i++){
      const r=rows[i],st=cv(r,iSt).toUpperCase(),no=cv(r,iNo);
      if(!st||!no||st==="STATUS")continue;
      allUnits.push({status:st,nopol:no,regional:cv(r,iReg),tahun:cv(r,iTh),jenis:cv(r,iJn),merek:cv(r,iMr),bisnis:cv(r,iBs)});
    }

    const now=new Date();
    const ts=now.toLocaleDateString("id-ID",{day:"2-digit",month:"short",year:"numeric"})+" "+now.toLocaleTimeString("id-ID",{hour:"2-digit",minute:"2-digit",second:"2-digit"});
    ["syncTime","sbTime"].forEach((id,i)=>{const el=document.getElementById(id);if(el)el.textContent=i===0?ts:"Update: "+ts;});
    const s2=document.getElementById("syncSub"); if(s2)s2.textContent=`${allUnits.length} unit · ${json.sheet||"KBM Investasi"}`;

    document.getElementById("errBar").style.display="none";
    startCd(); render();
  }catch(e){
    const b=document.getElementById("errBar"); document.getElementById("errMsg").textContent=e.message; b.style.display="flex";
    if(allUnits.length===0) document.getElementById("dash").innerHTML=`<div class="state-box"><div style="font-size:2rem;margin-bottom:.75rem">⚠️</div><h2>Gagal memuat data</h2><p>${e.message}</p></div>`;
  }finally{
    if(btn)btn.classList.remove("loading");
  }
}

function render(){
  const total=allUnits.length;
  const bySt={},byReg={},bdReg={};
  allUnits.forEach(u=>{
    bySt[u.status]=(bySt[u.status]||0)+1;
    byReg[u.regional]=(byReg[u.regional]||0)+1;
    if(u.status==="BREAKDOWN")bdReg[u.regional]=(bdReg[u.regional]||0)+1;
  });
  const nR=bySt["READY"]||0,nB=bySt["BREAKDOWN"]||0,nM=bySt["MANGKRAK"]||0,nL=bySt["LAKA"]||0,nP=bySt["PROGRES"]||0;
  const pR=total?+(nR/total*100).toFixed(2):0, pB=total?+(nB/total*100).toFixed(2):0;
  const kR=pR>=KPI_R, kB=pB<=KPI_B;
  const gR=(pR-KPI_R).toFixed(1), gB=(pB-KPI_B).toFixed(1);
  const uGap=Math.ceil((KPI_R/100*total)-nR), bGap=Math.ceil((pB-KPI_B)/100*total);
  const regSort=Object.entries(byReg).sort((a,b)=>b[1]-a[1]), maxR=regSort[0]?.[1]||1;
  const pct=v=>total?(v/total*100).toFixed(1)+"%":"0%";

  document.getElementById("dash").innerHTML=`
  <div class="sec-title fu fu1">Fleet Status</div>
  <div class="sg fu fu1">
    ${[
      {l:"Ready",      v:nR,   p:pct(nR), c:"cteal",   i:"✈"},
      {l:"Breakdown",  v:nB,   p:pct(nB), c:"cpink",   i:"⚠"},
      {l:"Mangkrak",   v:nM,   p:pct(nM), c:"camber",  i:"⏸"},
      {l:"Laka",       v:nL,   p:pct(nL), c:"cpurple", i:"🔴"},
      {l:"Progres",    v:nP,   p:pct(nP), c:"cblue",   i:"🔄"},
      {l:"Total Armada",v:total,p:"100%",  c:"cindigo", i:"🚛"},
    ].map(c=>`<div class="sc ${c.c}"><div class="sc-icon">${c.i}</div><div class="sc-val">${c.v}</div><div class="sc-lbl">${c.l}</div><div class="sc-pct">${c.p} dari total</div></div>`).join('')}
  </div>

  <div class="sec-title fu fu2">KPI Ketersediaan Armada</div>
  <div class="kgrid fu fu2">
    <div class="kc ${kR?'kpass':'kfail'}">
      <div class="kh"><div class="klbl">KPI #1 — Unit Ready</div><span class="badge ${kR?'pass':'fail'}">${kR?'✓ Tercapai':'✗ Tidak Tercapai'}</span></div>
      <div class="knum"><span class="kbig" style="color:${kR?'#065F46':'#991B1B'}">${pR.toFixed(1)}%</span><span class="ktgt">/ target ≥ ${KPI_R}%</span></div>
      <div class="pt"><div class="pf" id="pf1" style="width:0%;background:${kR?'#34D399':'#F87171'}"></div><div class="pm" style="left:${KPI_R}%"></div></div>
      <div class="pl"><span>0%</span><span>target ${KPI_R}%</span><span>100%</span></div>
      <div class="knote ${kR?'pass':'fail'}">${kR?`Surplus <strong>${Math.abs(+gR).toFixed(1)}%</strong> di atas target`:`Kurang <strong>${Math.abs(+gR).toFixed(1)}%</strong> — perlu <strong>+${uGap} unit</strong> kembali ready`}</div>
    </div>
    <div class="kc ${kB?'kpass':'kfail'}">
      <div class="kh"><div class="klbl">KPI #2 — Unit Breakdown</div><span class="badge ${kB?'pass':'fail'}">${kB?'✓ Tercapai':'✗ Tidak Tercapai'}</span></div>
      <div class="knum"><span class="kbig" style="color:${kB?'#065F46':'#991B1B'}">${pB.toFixed(1)}%</span><span class="ktgt">/ batas maks ≤ ${KPI_B}%</span></div>
      <div class="pt"><div class="pf" id="pf2" style="width:0%;background:${kB?'#34D399':'#F87171'}"></div><div class="pm" style="left:${KPI_B*2}%"></div></div>
      <div class="pl"><span>0%</span><span>batas ${KPI_B}%</span><span>50%+</span></div>
      <div class="knote ${kB?'pass':'fail'}">${kB?`Di bawah batas — aman <strong>${Math.abs(+gB).toFixed(1)}%</strong>`:`Melampaui <strong>${Math.abs(+gB).toFixed(1)}%</strong> — kurangi <strong>${bGap} unit</strong> breakdown`}</div>
    </div>
  </div>

  <div class="sec-title fu fu3">Distribusi Armada</div>
  <div class="mgrid fu fu3">
    <div class="card"><h3>Komposisi Status</h3><div style="position:relative;height:210px"><canvas id="donutChart" role="img" aria-label="Komposisi status armada"></canvas></div></div>
    <div class="card"><h3>Per Regional Office</h3>
      <div class="rlist">${regSort.map(([reg,cnt])=>`
        <div class="ri">
          <div class="rn" title="${reg}">${reg||'-'}</div>
          <div class="rbw"><div class="rb" style="width:${cnt/maxR*100}%"></div></div>
          <div class="rc">${cnt}</div>
          <div class="rbd">${bdReg[reg]?`▲${bdReg[reg]} BD`:''}</div>
        </div>`).join('')}
      </div>
    </div>
  </div>

  <div class="sec-title fu fu4">Daftar Unit Kendaraan</div>
  <div class="tcard fu fu4">
    <div class="fstrip" id="fstrip"></div>
    <table><thead><tr><th>#</th><th>Nopol</th><th>Status</th><th>Regional</th><th>Tahun</th><th>Jenis</th><th>Merek</th><th>Bisnis</th></tr></thead>
    <tbody id="tBody"></tbody></table>
    <div class="pgrow"><div class="pginfo" id="pgInfo"></div><div class="pgbtns" id="pgBtns"></div></div>
  </div>`;

  requestAnimationFrame(()=>setTimeout(()=>{
    const p1=document.getElementById("pf1"),p2=document.getElementById("pf2");
    if(p1)p1.style.width=Math.min(pR,100)+"%";
    if(p2)p2.style.width=Math.min(pB*2,100)+"%";
  },80));

  if(donutChart){donutChart.destroy();donutChart=null;}
  const ctx=document.getElementById("donutChart");
  if(ctx) donutChart=new Chart(ctx,{
    type:"doughnut",
    data:{labels:["READY","BREAKDOWN","MANGKRAK","LAKA","PROGRES"],
      datasets:[{data:["READY","BREAKDOWN","MANGKRAK","LAKA","PROGRES"].map(l=>bySt[l]||0),
        backgroundColor:["#2DD4BF","#F87171","#F59E0B","#A78BFA","#60A5FA"],
        borderWidth:3,borderColor:"#FFFFFF",hoverOffset:5}]},
    options:{responsive:true,maintainAspectRatio:false,cutout:"64%",
      plugins:{legend:{position:"bottom",labels:{color:"#6B7280",font:{size:11,family:"Inter"},padding:10,boxWidth:9}},
        tooltip:{callbacks:{label:c=>`  ${c.raw} unit (${total?(c.raw/total*100).toFixed(1):0}%)`}}}}
  });

  const filters=["ALL","READY","BREAKDOWN","MANGKRAK","LAKA","PROGRES"];
  document.getElementById("fstrip").innerHTML=
    filters.map(f=>`<button class="fb ${curFilter===f?'on':''}" onclick="setFilter('${f}')">${f} (${f==="ALL"?total:bySt[f]||0})</button>`).join('')+
    `<input class="sbox" placeholder="Cari nopol / regional..." oninput="onSearch(this.value)" value="${searchQ}"/>`;

  curFilter="ALL";curPage=1;searchQ="";applyFilter();
}

function setFilter(f){curFilter=f;curPage=1;document.querySelectorAll(".fb").forEach(b=>b.classList.toggle("on",b.textContent.trim().startsWith(f)));applyFilter();}
function onSearch(v){searchQ=v.toLowerCase();curPage=1;applyFilter();}
function applyFilter(){
  let d=allUnits;
  if(curFilter!=="ALL")d=d.filter(u=>u.status===curFilter);
  if(searchQ)d=d.filter(u=>u.nopol.toLowerCase().includes(searchQ)||u.regional.toLowerCase().includes(searchQ)||u.jenis.toLowerCase().includes(searchQ));
  filteredUnits=d;renderTable();
}
function renderTable(){
  const tot=filteredUnits.length,pages=Math.max(1,Math.ceil(tot/PG));
  curPage=Math.min(curPage,pages);
  const start=(curPage-1)*PG,slice=filteredUnits.slice(start,start+PG);
  document.getElementById("tBody").innerHTML=slice.map((u,i)=>`
    <tr>
      <td class="d" style="font-size:.69rem">${start+i+1}</td>
      <td style="font-weight:600;font-size:.77rem">${u.nopol}</td>
      <td><span class="pill p${u.status}">${u.status}</span></td>
      <td class="d">${u.regional||'-'}</td><td class="d">${u.tahun||'-'}</td>
      <td class="d">${u.jenis||'-'}</td><td class="d">${u.merek||'-'}</td><td class="d">${u.bisnis||'-'}</td>
    </tr>`).join('');
  document.getElementById("pgInfo").textContent=`${start+1}–${Math.min(start+PG,tot)} dari ${tot} unit`;
  let b=`<button class="pgb" onclick="goPage(${curPage-1})" ${curPage===1?"disabled":""}>←</button>`;
  for(let p=Math.max(1,curPage-2);p<=Math.min(pages,curPage+2);p++)
    b+=`<button class="pgb ${p===curPage?'on':''}" onclick="goPage(${p})">${p}</button>`;
  b+=`<button class="pgb" onclick="goPage(${curPage+1})" ${curPage===pages?"disabled":""}>→</button>`;
  document.getElementById("pgBtns").innerHTML=b;
}
function goPage(p){curPage=p;renderTable();}

loadData();
setInterval(()=>loadData(),REFRESH_MS);
</script>

<script>
if ('serviceWorker' in navigator) {
  window.addEventListener('load', () => {
    navigator.serviceWorker.register('sw.js')
      .then(r => console.log('SW registered'))
      .catch(e => console.log('SW error', e));
  });
}
</script>

<script>
let deferredPrompt = null;
window.addEventListener('beforeinstallprompt', (e) => {
  e.preventDefault();
  deferredPrompt = e;
  const banner = document.getElementById('installBanner');
  if (banner) banner.style.display = 'flex';
});
document.addEventListener('click', function(e) {
  if (e.target && e.target.id === 'btnInstall') {
    if (deferredPrompt) {
      deferredPrompt.prompt();
      deferredPrompt.userChoice.then(r => {
        deferredPrompt = null;
        document.getElementById('installBanner').style.display = 'none';
      });
    }
  }
});
window.addEventListener('appinstalled', () => {
  const banner = document.getElementById('installBanner');
  if (banner) banner.style.display = 'none';
  deferredPrompt = null;
});
</script>
</body>
</html>

{
  "name": "KPI Fleet Dashboard",
  "short_name": "KPI Fleet",
  "description": "Dashboard KPI Armada KBM Investasi — PT Pos Logistik Indonesia",
  "start_url": "/fleet-dashboard/",
  "scope": "/fleet-dashboard/",
  "display": "standalone",
  "orientation": "portrait",
  "background_color": "#F4F6FA",
  "theme_color": "#4F46E5",
  "lang": "id",
  "icons": [
    {
      "src": "icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "categories": ["business", "productivity"],
  "screenshots": []
}

const CACHE = 'kpi-fleet-v1';
const ASSETS = [
  '/fleet-dashboard/',
  '/fleet-dashboard/index.html',
  'https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js',
  'https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap'
];

// Install — cache semua aset
self.addEventListener('install', e => {
  e.waitUntil(
    caches.open(CACHE).then(c => {
      return Promise.allSettled(ASSETS.map(url => c.add(url).catch(() => null)));
    })
  );
  self.skipWaiting();
});

// Activate — hapus cache lama
self.addEventListener('activate', e => {
  e.waitUntil(
    caches.keys().then(keys =>
      Promise.all(keys.filter(k => k !== CACHE).map(k => caches.delete(k)))
    )
  );
  self.clients.claim();
});

// Fetch — cache first untuk aset statis, network first untuk API
self.addEventListener('fetch', e => {
  const url = new URL(e.request.url);

  // API Google Apps Script — selalu ambil dari network (data real-time)
  if (url.hostname.includes('script.google.com')) {
    e.respondWith(
      fetch(e.request).catch(() =>
        new Response(JSON.stringify({ error: 'Offline — tidak ada koneksi internet' }), {
          headers: { 'Content-Type': 'application/json' }
        })
      )
    );
    return;
  }

  // Aset statis — cache first
  e.respondWith(
    caches.match(e.request).then(cached => {
      if (cached) return cached;
      return fetch(e.request).then(res => {
        if (res && res.status === 200) {
          const clone = res.clone();
          caches.open(CACHE).then(c => c.put(e.request, clone));
        }
        return res;
      }).catch(() => cached);
    })
  );
});
